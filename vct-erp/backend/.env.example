APP_ENV=development
HTTP_ADDR=:8080
HTTP_READ_TIMEOUT=15s
HTTP_WRITE_TIMEOUT=15s
HTTP_IDLE_TIMEOUT=60s
HTTP_SHUTDOWN_TIMEOUT=10s
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

DB_DSN=postgres://postgres:vct_erp_2026@localhost:5432/vct_ledger?sslmode=disable
DB_MAX_OPEN_CONNS=20
DB_MAX_IDLE_CONNS=10
DB_CONN_MAX_LIFETIME=30m

REDIS_URL=redis://localhost:6379/0
REDIS_ADDR=localhost:6379
REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_DB=0
APP_ROLE_HEADER=X-App-Role
APP_ACTOR_HEADER=X-Actor-ID
IDEMPOTENCY_HEADER=Idempotency-Key
REDIS_STREAM_KEY=ledger.events
FINANCE_EVENTS_CHANNEL=finance.dashboard.events
ACCOUNT_CACHE_TTL=15m
DASHBOARD_CACHE_TTL=60s
MONGO_URI=mongodb://localhost:2717
MONGO_DATABASE=vct_finance
MONGO_AUDIT_COLLECTION=ledger_void_audit
OUTBOX_RELAY_INTERVAL=5s
OUTBOX_RELAY_RETRY_DELAY=30s
OUTBOX_RELAY_CLAIM_TTL=2m
OUTBOX_RELAY_BATCH_SIZE=100
OUTBOX_RELAY_RUN_TIMEOUT=20s
