APP_ENV=development
HTTP_ADDR=:8080
HTTP_READ_TIMEOUT=15s
HTTP_WRITE_TIMEOUT=15s
HTTP_IDLE_TIMEOUT=60s
HTTP_SHUTDOWN_TIMEOUT=10s

DB_DSN=postgres://postgres:postgres@localhost:5432/vct_ledger?sslmode=disable

REDIS_ADDR=localhost:6379
REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_DB=0
APP_ROLE_HEADER=X-App-Role
IDEMPOTENCY_HEADER=Idempotency-Key
REDIS_STREAM_KEY=ledger.events
ACCOUNT_CACHE_TTL=15m
OUTBOX_RELAY_INTERVAL=5s
OUTBOX_RELAY_RETRY_DELAY=30s
OUTBOX_RELAY_CLAIM_TTL=2m
OUTBOX_RELAY_BATCH_SIZE=100
