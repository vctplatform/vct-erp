# ─── VCT CMS Backend Environment Variables ───

# JWT Secret — BẮT BUỘC thay đổi cho production!
JWT_SECRET=your-super-secret-key-at-least-32-chars

# Server Port
PORT=8080

# CORS — danh sách origin được phép (phân cách bởi dấu phẩy)
CORS_ORIGINS=http://localhost:3000, https://vct-platform.github.io
